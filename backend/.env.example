NODE_ENV=development
PORT=3001
REQUEST_SIZE_LIMIT=1mb
CORS_ORIGIN=http://localhost:54321,http://127.0.0.1:54321,http://localhost:3000
AI_PROVIDER=openai

# Keep this server-side only. Flutter must never receive or embed this value.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT_MS=45000
